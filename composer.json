{
  "name": "rak200/sql-builder",
  "description": "Fluent SQL query and schema builder for PHP 8.4+",
  "version": "0.5.0",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "rak200",
      "email": "rak.ricardo@windowslive.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "rak200/caster": "^1.0.0",
    "rak200/collections": "0.*"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/rak200/caster"
    },
    {
      "type": "vcs",
      "url": "https://github.com/rak200/collections"
    }
  ],
  "autoload": {
    "psr-4": {
      "Rak200\\SqlBuilder\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Rak200\\SqlBuilder\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1"
  },
  "scripts": {
    "test": "phpunit"
  }
}
